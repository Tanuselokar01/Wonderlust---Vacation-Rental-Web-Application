<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
    <div class="col-6 offset-3"></div>

  <h1 class="col-6 offset-3">SignUp on WonderLust</h1>
    
  <form action="signup" method="POST" class="needs-validation" novalidate>
  <div class="mb-3">
  <label for="username" class="form label">Username</label>
  <input
   name="username" 
   id="username" 
   type="text"
   class="form-control"
    required>
  <div class="valid-feedback"> Looks good!</div>
  </div>

  <div class="mb-3">
  <label for="email" class="form label">Email</label>
  <input
   name="email" 
   id="email" 
   type="email"
   class="form-control"
    required>
  </input>
  </div>

  <div class="mb-3">
  <label for="passward" class="form label">Passward</label>
  <input
   name="passward" 
   id="passward" 
   type="passward"
   class="form-control"
   required>
  </div>
  <button class="btn btn-success">SignUp</button>
  </form>
  </div>
  </div>