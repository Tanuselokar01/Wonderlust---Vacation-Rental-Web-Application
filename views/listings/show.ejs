<% layout("/layouts/boilerplate") %>

<script>
  window.mapToken = "<%= mapToken %>";
  window.listing = <%- JSON.stringify(listing) %>;
</script>

<div class="container mt-4">

  <!-- TITLE -->
  <div class="row">
    <div class="col-12 col-md-10 col-lg-8 mx-auto">
      <h3 class="mb-3"><%= listing.title %></h3>
    </div>
  </div>

  <!-- LISTING CARD -->
  <div class="row">

    <div class="col-12 col-md-10 col-lg-8 mx-auto">

      <div class="card listing-card shadow-sm">

        <img 
          src="<%= listing.image.url %>" 
          class="card-img-top img-fluid"
          style="height: 400px; object-fit: cover;"
          alt="listing_image">

        <div class="card-body">

          <p class="card-text">
            <i>Owned by <%= listing.owner ? listing.owner.username : "No owner" %></i>
          </p>

          <p class="card-text"><%= listing.description %></p>

          <p class="card-text">
            ₹<%= listing.price.toLocaleString("en-IN") %>
          </p>

          <p class="card-text">
            <%= listing.location %>, <%= listing.country %>
          </p>

        </div>

      </div>

    </div>
  </div>

  <!-- OWNER BUTTONS -->
  <% if(currUser && listing.owner._id.equals(currUser._id)) { %>

    <div class="row mt-3">
      <div class="col-12 col-md-10 col-lg-8 mx-auto d-flex gap-2">

        <a 
          href="/listings/<%= listing._id %>/edit" 
          class="btn btn-dark flex-fill">
          Edit
        </a>

        <form 
          method="POST" 
          action="/listings/<%= listing._id %>?_method=DELETE"
          class="flex-fill">

          <button class="btn btn-danger w-100">
            Delete
          </button>

        </form>

      </div>
    </div>

  <% } %>

  <!-- REVIEW FORM -->
  <div class="row mt-4">

    <div class="col-12 col-md-10 col-lg-8 mx-auto">

      <% if(currUser) { %>

        <hr>
        <h4>Leave a Review</h4>

        <form 
          action="/listings/<%= listing._id %>/reviews" 
          method="POST" 
          novalidate 
          class="needs-validation">

          <!-- STAR RATING -->
          <div class="mb-3 mt-3">

            <label class="form-label">Rating</label>

            <fieldset class="starability-slot">

              <input type="radio" id="no-rate" class="input-no-rate"
                name="review[rating]" value="0" checked>

              <input type="radio" id="rate1" name="review[rating]" value="1">
              <label for="rate1">1 star</label>

              <input type="radio" id="rate2" name="review[rating]" value="2">
              <label for="rate2">2 stars</label>

              <input type="radio" id="rate3" name="review[rating]" value="3">
              <label for="rate3">3 stars</label>

              <input type="radio" id="rate4" name="review[rating]" value="4">
              <label for="rate4">4 stars</label>

              <input type="radio" id="rate5" name="review[rating]" value="5">
              <label for="rate5">5 stars</label>

            </fieldset>

          </div>

          <!-- COMMENT -->
          <div class="mb-3">
            <label class="form-label">Comment</label>
            <textarea 
              name="review[comment]" 
              class="form-control"
              rows="4"
              required></textarea>
          </div>

          <button class="btn btn-outline-dark">
            Submit Review
          </button>

        </form>

        <hr>

      <% } %>

    </div>
  </div>

  <!-- REVIEWS -->
  <% if(listing.reviews.length > 0) { %>

    <div class="row">

      <div class="col-12 col-md-10 col-lg-8 mx-auto">

        <h4 class="mb-3">All Reviews</h4>

        <div class="row g-3">

          <% for (let review of listing.reviews) { %>

            <div class="col-12 col-md-6">

              <div class="card h-100 shadow-sm">

                <div class="card-body">

                  <h6>@<%= review.author.username %></h6>

                  <p class="starability-result"
                     data-rating="<%= review.rating %>"></p>

                  <p><%= review.comment %></p>

                  <form 
                    method="POST" 
                    action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">

                    <button class="btn btn-sm btn-dark">
                      Delete
                    </button>

                  </form>

                </div>

              </div>

            </div>

          <% } %>

        </div>

      </div>

    </div>

  <% } %>

  <!-- MAP (RESPONSIVE FIXED) -->
  <div class="container my-4">
    <div class="row">
      <div class="col-12 col-md-10 col-lg-8 mx-auto">

        <h3 class="mb-3">Where you'll be</h3>

        <div id="map"></div>

      </div>
    </div>
  </div>

</div>

<script src="/js/map.js"></script>