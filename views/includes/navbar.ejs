<style>
  .custom-btn {
    background-color: #fe424d;
    color: #fff;
    border-radius: 25px;
    padding: 0.4rem 1rem;
  }

  .custom-btn:hover {
    background-color: #e63946;
    color: #fff;
  }

  .search-input {
    border-radius: 25px;
    padding: 0.5rem 1.5rem;
  }

  .navbar-search {
    width: 100%;
    max-width: 500px;
  }

  @media (max-width: 768px) {
    .navbar-search {
      width: 100%;
      margin-top: 10px;
    }
  }
</style>

<nav class="navbar navbar-expand-lg bg-body-light border-bottom sticky-top">

  <div class="container-fluid">

    <!-- BRAND -->
    <a class="navbar-brand" href="/listings">
      <i class="fa-regular fa-compass"></i>
    </a>

    <!-- TOGGLER -->
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- COLLAPSE -->
    <div class="collapse navbar-collapse" id="navbarNav">

      <!-- LEFT -->
      <ul class="navbar-nav me-auto">
        <li class="nav-item">
          <a class="nav-link" href="/listings">Explore</a>
        </li>
      </ul>

      <!-- CENTER SEARCH -->
      <form class="d-flex navbar-search mx-lg-auto my-2 my-lg-0">
        <input class="form-control search-input me-2" type="search" placeholder="Search destinations">
        <button class="custom-btn d-flex align-items-center" type="submit">
          <i class="fa-solid fa-magnifying-glass me-2"></i>
          Search
        </button>
      </form>

      <!-- RIGHT -->
      <ul class="navbar-nav ms-auto align-items-lg-center">

        <li class="nav-item">
          <a class="nav-link" href="/listings/new">Airbnb your home</a>
        </li>

        <% if(!currUser) { %>

          <li class="nav-item">
            <a class="nav-link" href="/signup"><b>Sign up</b></a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/login"><b>Log in</b></a>
          </li>

        <% } else { %>

          <li class="nav-item">
            <a class="nav-link" href="/logout"><b>Log out</b></a>
          </li>

        <% } %>

      </ul>

    </div>

  </div>
</nav>