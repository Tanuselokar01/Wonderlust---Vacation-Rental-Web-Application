<style>
  .custom-btn {
    background-color: #fe424d;
    color: #fff;
    border-radius: 25px;
    padding: 0.4rem 1rem;
    border: none;
    white-space: nowrap;
  }

  .custom-btn:hover {
    background-color: #e63946;
    color: #fff;
  }

  .search-input {
    border-radius: 25px;
    padding: 0.5rem 1rem;
  }

  .navbar-search {
    width: 100%;
    max-width: 450px;
  }

  /* IMPORTANT FIX */
  @media (max-width: 992px) {
    .navbar-search {
      flex-direction: column;
      width: 100%;
      margin: 10px 0;
    }

    .search-input {
      margin-bottom: 8px;
    }

    .custom-btn {
      width: 100%;
    }
  }
</style>

<nav class="navbar navbar-expand-lg bg-body-light border-bottom sticky-top">

  <div class="container-fluid">

    <!-- BRAND -->
    <a class="navbar-brand" href="/listings">
      <i class="fa-regular fa-compass"></i>
    </a>

    <!-- TOGGLER -->
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- COLLAPSE -->
    <div class="collapse navbar-collapse" id="navbarNav">

      <!-- LEFT -->
      <ul class="navbar-nav me-auto">
        <li class="nav-item">
          <a class="nav-link" href="/listings">Explore</a>
        </li>
      </ul>

      <!-- SEARCH -->
      <form class="d-flex navbar-search mx-lg-auto flex-column flex-lg-row">

        <input 
          class="form-control search-input me-lg-2 mb-2 mb-lg-0" 
          type="search" 
          placeholder="Search destinations">

        <button class="custom-btn" type="submit">
          <i class="fa-solid fa-magnifying-glass me-1"></i>
          Search
        </button>

      </form>

      <!-- RIGHT -->
      <ul class="navbar-nav ms-auto">

        <li class="nav-item">
          <a class="nav-link" href="/listings/new">Airbnb your home</a>
        </li>

        <% if(!currUser) { %>

          <li class="nav-item">
            <a class="nav-link" href="/signup"><b>Sign up</b></a>
          </li>

          <li class="nav-item">
            <a class="nav-link" href="/login"><b>Log in</b></a>
          </li>

        <% } else { %>

          <li class="nav-item">
            <a class="nav-link" href="/logout"><b>Log out</b></a>
          </li>

        <% } %>

      </ul>

    </div>

  </div>
</nav>